:root{--navy:#173f5f;--blue:#20639b;--green:#2d936c;--red:#c0392b;--yellow:#f1b72c;--bg:#f3f6f8;--line:#dce3e8}*{box-sizing:border-box}body{margin:0;font-family:Arial,sans-serif;background:var(--bg);color:#18323f}header{background:linear-gradient(135deg,var(--navy),var(--blue));color:white;padding:18px max(18px,calc((100% - 1200px)/2));display:flex;justify-content:space-between;align-items:center;gap:18px}.brand{display:flex;align-items:center;gap:14px}.brand img{width:78px;height:58px;object-fit:contain;background:white;border-radius:8px;padding:4px}.brand h1{margin:0;font-size:28px}.brand p{margin:3px 0 0;opacity:.85}main{max-width:1200px;margin:20px auto;padding:0 16px}button,.primary,.back{border:0;border-radius:11px;padding:13px 16px;cursor:pointer;font-weight:bold;text-decoration:none}.primary{background:var(--yellow);color:#18323f}.back{background:white;color:var(--navy)}.quick-head{display:grid;grid-template-columns:2fr 1fr;gap:12px}.quick-head a{border-radius:15px;padding:20px;text-decoration:none;font-weight:bold;font-size:19px;background:white;color:var(--navy);box-shadow:0 4px 16px #173f5f12}.quick-head .scan{background:var(--yellow)}.quick-head .order{color:var(--red)}.section-title{margin:24px 0 10px}.popular-grid,.product-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:12px}.quick-card,.product{background:white;border-radius:15px;padding:15px;border-left:7px solid var(--green);box-shadow:0 4px 16px #173f5f10}.quick-card.low,.product.low,.detail-card.low{border-left-color:var(--red);background:#fff8f7}.quick-card a,.product-link{text-decoration:none;color:inherit}.quick-card h3{margin:0}.bigstock{font-size:34px;font-weight:bold;margin:10px 0}.bigstock small{font-size:15px;color:#607786}.quick-buttons,.fast-four,.giant-buttons{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;margin-top:12px}.quick-buttons form,.fast-four form,.giant-buttons form{margin:0}.quick-buttons button,.fast-four button,.giant-buttons button{width:100%;font-size:20px;padding:14px}.out,.minus1{background:#fde4e0;color:#9b2f22}.in,.plus1{background:#dff4e9;color:#176947}.stats{display:grid;grid-template-columns:1fr 1fr auto;gap:12px;margin:20px 0}.stats article,.export{background:white;border-radius:14px;padding:16px;box-shadow:0 4px 16px #173f5f12}.stats strong{display:block;font-size:28px}.stats span{color:#607786}.warn strong{color:var(--red)}.export{display:flex;align-items:center;text-decoration:none;color:var(--navy);font-weight:bold}.filters{display:grid;grid-template-columns:2fr 1fr auto;gap:9px;background:white;padding:12px;border-radius:14px;margin-bottom:18px}.filters input,.filters select,.form-grid input,.form-grid select{width:100%;padding:13px;border:1px solid var(--line);border-radius:9px;font:inherit}.product-top{display:flex;justify-content:space-between;gap:8px}.product h2{margin:0 0 5px;font-size:18px}.product small{color:#6b7e88}.status-dot{font-size:11px;font-weight:bold}.product.low .status-dot{color:var(--red)}.stock{display:flex;align-items:baseline;gap:7px;margin:16px 0}.stock strong{font-size:40px}.stock span{color:#607786}.history{margin-top:22px;background:white;border-radius:14px;padding:16px}.table-wrap{overflow:auto}table{width:100%;border-collapse:collapse}th,td{text-align:left;padding:10px;border-bottom:1px solid var(--line)}.plus{color:var(--green);font-weight:bold}.minus{color:var(--red);font-weight:bold}.modal{display:none;position:fixed;inset:0;background:#102a3bbb;z-index:20;padding:18px;overflow:auto}.modal.show{display:flex;align-items:center;justify-content:center}.box{position:relative;background:white;border-radius:16px;padding:24px;width:min(700px,100%)}.box.small{width:min(500px,100%)}.close{position:absolute;right:10px;top:8px;background:none;font-size:26px}.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:13px}.form-grid label{font-size:13px;font-weight:bold}.wide{grid-column:1/-1}.empty{background:white;padding:25px;border-radius:14px;text-align:center}.detail-main{display:grid;grid-template-columns:2fr 1fr;gap:18px}.detail-card,.qr-card{background:white;border-radius:18px;padding:24px;box-shadow:0 4px 16px #173f5f12}.detail-card{border-left:8px solid var(--green);text-align:center}.detail-stock{font-size:72px;font-weight:bold}.detail-stock small{font-size:23px;color:#607786}.detail-status{font-size:20px;margin:8px}.giant-buttons button{font-size:32px;padding:24px}.other{margin-top:14px;width:100%;background:#eaf0f4}.qr-card{text-align:center}.qr-card img{width:min(260px,100%)}.download{display:inline-block}@media(max-width:720px){header{align-items:flex-start}.brand img{width:62px;height:48px}.brand h1{font-size:23px}.quick-head,.stats,.filters,.detail-main{grid-template-columns:1fr}.popular-grid,.product-grid{grid-template-columns:1fr}.form-grid{grid-template-columns:1fr}.wide{grid-column:auto}.stats .export{grid-column:1/-1}.detail-stock{font-size:58px}.giant-buttons button{font-size:28px;padding:20px}}
