function openModal(id){document.getElementById(id).classList.add('show')}function closeModal(id){document.getElementById(id).classList.remove('show')}
function openStock(id,dir,name){document.getElementById('stockForm').action=`/products/${id}/mutate`;document.getElementById('direction').value=dir;document.getElementById('stockTitle').textContent=(dir==='in'?'Voorraad inboeken: ':'Voorraad uitboeken: ')+name;openModal('stockModal')}
function openEdit(id,name,article,category,unit,location,min,notes){document.getElementById('editForm').action=`/products/${id}/edit`;document.getElementById('deleteForm').action=`/products/${id}/delete`;e_name.value=name;e_article.value=article;e_category.value=category;e_unit.value=unit;e_location.value=location;e_minimum.value=min;e_notes.value=notes;openModal('editModal')}
document.querySelectorAll('.modal').forEach(m=>m.addEventListener('click',e=>{if(e.target===m)m.classList.remove('show')}));if('serviceWorker'in navigator)navigator.serviceWorker.register('/static/sw.js');
